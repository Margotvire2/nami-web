{
  "version": "1.0",
  "source": "HAS 2010/2019, PNDS AMP 2022, DU TCA FFAB 2025-2026",
  "description": "Modèle de données de télésurveillance TCA — données à collecter par professionnel, seuils d'alerte automatisés, sources de saisie",

  "professionals": [
    {
      "id": "medecin-generaliste",
      "label": "Médecin généraliste / Pédiatre",
      "role": "coordinateur_somatique",
      "frequence_consultation": "hebdomadaire à mensuelle selon sévérité",
      "datasets": [
        {
          "category": "anthropometrie",
          "label": "Anthropométrie",
          "fields": [
            {
              "id": "poids",
              "label": "Poids",
              "type": "number",
              "unit": "kg",
              "precision": 1,
              "frequency": "each_consultation",
              "source": ["consultation", "ide", "patient_app"],
              "track_history": true,
              "alerts": [
                { "condition": "perte > 2 kg/semaine", "severity": "critical", "population": "enfant_ado", "message": "Perte de poids rapide — critère d'hospitalisation HAS" },
                { "condition": "perte > 20% en 3 mois", "severity": "critical", "population": "adulte", "message": "Perte pondérale majeure — critère d'hospitalisation HAS" },
                { "condition": "stagnation > 4 semaines sous objectif", "severity": "high", "message": "Stagnation pondérale — réévaluer la PEC" }
              ]
            },
            {
              "id": "taille",
              "label": "Taille",
              "type": "number",
              "unit": "cm",
              "precision": 1,
              "frequency": "mensuelle_enfant",
              "source": ["consultation"],
              "track_history": true,
              "alerts": [
                { "condition": "stagnation > 6 mois", "severity": "high", "population": "enfant_ado", "message": "Stagnation staturale — impact croissance" }
              ]
            },
            {
              "id": "imc",
              "label": "IMC",
              "type": "computed",
              "formula": "poids / (taille/100)²",
              "unit": "kg/m²",
              "precision": 1,
              "track_history": true,
              "alerts": [
                { "condition": "< 12", "severity": "critical", "population": "adulte", "message": "IMC ≤ 12 — RÉANIMATION" },
                { "condition": "< 14", "severity": "critical", "population": "adulte_17plus", "message": "IMC < 14 — critère d'hospitalisation" },
                { "condition": "< 13.2", "severity": "critical", "population": "ado_15_16", "message": "IMC < 13,2 — critère d'hospitalisation (15-16 ans)" },
                { "condition": "< 12.7", "severity": "critical", "population": "ado_13_14", "message": "IMC < 12,7 — critère d'hospitalisation (13-14 ans)" }
              ]
            },
            {
              "id": "pmbs",
              "label": "Poids Minimum de Bonne Santé (objectif)",
              "type": "number",
              "unit": "kg",
              "precision": 1,
              "frequency": "initial_puis_revision",
              "source": ["dieteticien", "consultation"],
              "notes": "PMBS = IMC cible × taille². IMC cible = couloir antérieur à la maladie."
            },
            {
              "id": "waterlow",
              "label": "Indice de Waterlow",
              "type": "computed",
              "formula": "poids / poids_attendu_taille × 100",
              "unit": "%",
              "population": "enfant",
              "alerts": [
                { "condition": "< 80", "severity": "high", "message": "Dénutrition modérée (Waterlow < 80%)" },
                { "condition": "< 70", "severity": "critical", "message": "Dénutrition sévère (Waterlow < 70%)" }
              ]
            }
          ]
        },
        {
          "category": "constantes",
          "label": "Constantes vitales",
          "fields": [
            {
              "id": "fc",
              "label": "Fréquence cardiaque",
              "type": "number",
              "unit": "bpm",
              "frequency": "each_consultation",
              "source": ["consultation", "ide", "patient_app_connected_device"],
              "track_history": true,
              "alerts": [
                { "condition": "< 40", "severity": "critical", "message": "Bradycardie < 40/min — critère d'hospitalisation" },
                { "condition": "< 50", "severity": "high", "population": "enfant_moins_12", "message": "Bradycardie < 50/min chez enfant < 12 ans — discuter hospitalisation (AAP 2021)" },
                { "condition": "> 60 si imc < 13", "severity": "critical", "message": "Tachycardie repos > 60/min avec IMC < 13 — critère d'hospitalisation" }
              ]
            },
            {
              "id": "pa_systolique",
              "label": "PA systolique",
              "type": "number",
              "unit": "mmHg",
              "frequency": "each_consultation",
              "source": ["consultation", "ide"],
              "alerts": [
                { "condition": "< 90", "severity": "critical", "population": "adulte", "message": "Hypotension < 90 mmHg — critère d'hospitalisation" },
                { "condition": "< 80", "severity": "critical", "population": "enfant_ado", "message": "PA < 80 mmHg — critère d'hospitalisation" }
              ]
            },
            {
              "id": "pa_diastolique",
              "label": "PA diastolique",
              "type": "number",
              "unit": "mmHg",
              "frequency": "each_consultation",
              "source": ["consultation", "ide"]
            },
            {
              "id": "hypotension_orthostatique",
              "label": "Hypotension orthostatique",
              "type": "boolean",
              "frequency": "each_consultation",
              "source": ["consultation"],
              "alerts": [
                { "condition": "true", "severity": "high", "message": "Hypotension orthostatique présente" }
              ]
            },
            {
              "id": "temperature",
              "label": "Température",
              "type": "number",
              "unit": "°C",
              "precision": 1,
              "frequency": "each_consultation",
              "source": ["consultation", "ide"],
              "alerts": [
                { "condition": "< 35", "severity": "critical", "population": "adulte", "message": "Hypothermie < 35°C — critère d'hospitalisation" },
                { "condition": "< 35.5", "severity": "critical", "population": "enfant_ado", "message": "Hypothermie < 35,5°C — critère d'hospitalisation" }
              ]
            }
          ]
        },
        {
          "category": "biologie",
          "label": "Biologie",
          "fields": [
            {
              "id": "kaliemie",
              "label": "Kaliémie (K+)",
              "type": "number",
              "unit": "mEq/L",
              "precision": 1,
              "source": ["laboratoire", "consultation_saisie"],
              "track_history": true,
              "alerts": [
                { "condition": "< 3", "severity": "critical", "message": "Hypokaliémie < 3 mEq/L — critère d'hospitalisation. ECG urgent." },
                { "condition": "< 3.5", "severity": "high", "message": "Hypokaliémie modérée — surveillance rapprochée" }
              ]
            },
            {
              "id": "natremie",
              "label": "Natrémie (Na+)",
              "type": "number",
              "unit": "mmol/L",
              "precision": 0,
              "source": ["laboratoire"],
              "track_history": true,
              "alerts": [
                { "condition": "< 125", "severity": "critical", "message": "Hyponatrémie < 125 — risque convulsions (potomanie)" },
                { "condition": "> 150", "severity": "critical", "message": "Hypernatrémie > 150 — déshydratation sévère" }
              ]
            },
            {
              "id": "phosphoremie",
              "label": "Phosphorémie",
              "type": "number",
              "unit": "mmol/L",
              "precision": 2,
              "source": ["laboratoire"],
              "track_history": true,
              "alerts": [
                { "condition": "< 0.5", "severity": "critical", "message": "Hypophosphorémie < 0,5 — critère d'hospitalisation. Marqueur SRI." },
                { "condition": "baisse > 30% en 72h", "severity": "critical", "message": "Chute brutale phosphore — ALERTE SRI" }
              ]
            },
            {
              "id": "magnesemie",
              "label": "Magnésémie",
              "type": "number",
              "unit": "mmol/L",
              "precision": 2,
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 0.7", "severity": "high", "message": "Hypomagnésémie — corriger (aggrave l'hypokaliémie)" }
              ]
            },
            {
              "id": "glycemie",
              "label": "Glycémie",
              "type": "number",
              "unit": "g/L",
              "precision": 2,
              "source": ["laboratoire", "ide_capillaire"],
              "alerts": [
                { "condition": "< 0.6 symptomatique", "severity": "critical", "message": "Hypoglycémie symptomatique — critère d'hospitalisation" },
                { "condition": "< 0.3", "severity": "critical", "message": "Hypoglycémie sévère < 0,3 g/L — critère d'hospitalisation même asymptomatique" }
              ]
            },
            {
              "id": "hemoglobine",
              "label": "Hémoglobine",
              "type": "number",
              "unit": "g/dL",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 10", "severity": "high", "message": "Anémie — rechercher carence" }
              ]
            },
            {
              "id": "leucocytes",
              "label": "Leucocytes",
              "type": "number",
              "unit": "/mm³",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 1000", "severity": "critical", "message": "Leucopénie < 1000 — critère d'hospitalisation" }
              ]
            },
            {
              "id": "pnn",
              "label": "Polynucléaires neutrophiles",
              "type": "number",
              "unit": "/mm³",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 500", "severity": "critical", "message": "Neutropénie < 500 — critère d'hospitalisation" }
              ]
            },
            {
              "id": "plaquettes",
              "label": "Plaquettes",
              "type": "number",
              "unit": "/mm³",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 60000", "severity": "critical", "message": "Thrombopénie < 60 000 — critère d'hospitalisation" }
              ]
            },
            {
              "id": "alat",
              "label": "ALAT",
              "type": "number",
              "unit": "UI/L",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "> 4xN", "severity": "critical", "population": "enfant_ado", "message": "Cytolyse > 4×N — critère d'hospitalisation enfant" },
                { "condition": "> 10xN", "severity": "critical", "population": "adulte", "message": "Cytolyse > 10×N — critère d'hospitalisation adulte. Si signes IHC → réanimation" }
              ]
            },
            {
              "id": "creatinine",
              "label": "Créatinine",
              "type": "number",
              "unit": "µmol/L",
              "source": ["laboratoire"]
            },
            {
              "id": "clairance_creat",
              "label": "Clairance créatinine",
              "type": "number",
              "unit": "mL/min",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 40", "severity": "critical", "message": "Insuffisance rénale (clairance < 40) — critère d'hospitalisation" }
              ]
            },
            {
              "id": "albumine",
              "label": "Albumine",
              "type": "number",
              "unit": "g/L",
              "source": ["laboratoire"],
              "notes": "Marqueur nutritionnel long terme (demi-vie 20j). Peut être faussement normal si hémoconcentration."
            },
            {
              "id": "prealbumine",
              "label": "Préalbumine",
              "type": "number",
              "unit": "g/L",
              "source": ["laboratoire"],
              "notes": "Marqueur nutritionnel court terme (demi-vie 2j). Utile pour le suivi de la renutrition."
            },
            {
              "id": "tsh",
              "label": "TSH",
              "type": "number",
              "unit": "mUI/L",
              "source": ["laboratoire"],
              "notes": "Non recommandé en routine sauf doute diagnostique (hyperthyroïdie). Sd basse T3 = adaptation, pas hypothyroïdie."
            },
            {
              "id": "vitamine_d",
              "label": "25-OH Vitamine D",
              "type": "number",
              "unit": "ng/mL",
              "source": ["laboratoire"],
              "alerts": [
                { "condition": "< 20", "severity": "moderate", "message": "Carence en vitamine D — supplémentation" }
              ]
            }
          ]
        },
        {
          "category": "ecg",
          "label": "ECG",
          "fields": [
            {
              "id": "qtc",
              "label": "QTc",
              "type": "number",
              "unit": "ms",
              "source": ["consultation"],
              "alerts": [
                { "condition": "> 450", "severity": "critical", "message": "QTc allongé > 450 ms — risque torsade de pointe" }
              ]
            },
            {
              "id": "ecg_anomalie",
              "label": "Anomalie ECG",
              "type": "boolean",
              "source": ["consultation"],
              "alerts": [
                { "condition": "true", "severity": "critical", "message": "Anomalie ECG (hors FC) — critère d'hospitalisation" }
              ]
            },
            {
              "id": "onde_u",
              "label": "Onde U présente",
              "type": "boolean",
              "source": ["consultation"],
              "alerts": [
                { "condition": "true", "severity": "high", "message": "Onde U — signe d'hypokaliémie, vérifier ionogramme" }
              ]
            }
          ]
        },
        {
          "category": "puberte",
          "label": "Puberté et croissance",
          "population": "enfant_ado",
          "fields": [
            {
              "id": "tanner",
              "label": "Stade de Tanner",
              "type": "select",
              "options": ["1", "2", "3", "4", "5"],
              "source": ["consultation"],
              "frequency": "trimestrielle",
              "alerts": [
                { "condition": "stagnation > 1 an", "severity": "high", "message": "Retard ou arrêt pubertaire — avis endocrino" }
              ]
            },
            {
              "id": "age_osseux",
              "label": "Âge osseux",
              "type": "number",
              "unit": "ans",
              "source": ["radiologie"],
              "notes": "Rx main-poignet gauche. Utile si retard de croissance."
            }
          ]
        },
        {
          "category": "amenorrhee",
          "label": "Cycles menstruels",
          "fields": [
            {
              "id": "type_amenorrhee",
              "label": "Type d'aménorrhée",
              "type": "select",
              "options": ["pas_amenorrhee", "primaire", "secondaire", "sous_contraception"],
              "source": ["consultation", "patient_app"]
            },
            {
              "id": "date_dernieres_regles",
              "label": "Date dernières règles",
              "type": "date",
              "source": ["consultation", "patient_app"],
              "alerts": [
                { "condition": "> 6 mois", "severity": "moderate", "message": "Aménorrhée > 6 mois — ostéodensitométrie recommandée" }
              ]
            },
            {
              "id": "contraception",
              "label": "Contraception",
              "type": "text",
              "source": ["consultation"]
            }
          ]
        }
      ]
    },
    {
      "id": "psychiatre",
      "label": "Psychiatre / Pédopsychiatre",
      "role": "coordinateur_psychiatrique",
      "frequence_consultation": "hebdomadaire à bimensuelle",
      "datasets": [
        {
          "category": "diagnostic_tca",
          "label": "Diagnostic TCA",
          "fields": [
            { "id": "type_tca", "label": "Type de TCA", "type": "select", "options": ["AN_restrictive", "AN_binge_purge", "BN", "BED", "ARFID", "TCA_non_specifie"], "source": ["consultation"] },
            { "id": "severite_dsm5", "label": "Sévérité DSM-5", "type": "select", "options": ["leger", "modere", "grave", "extreme"], "source": ["consultation"] },
            { "id": "anciennete_mois", "label": "Ancienneté du trouble", "type": "number", "unit": "mois", "source": ["consultation"] },
            { "id": "atcd_tca", "label": "ATCD de TCA (autres types)", "type": "text", "source": ["consultation"] }
          ]
        },
        {
          "category": "risque_suicidaire",
          "label": "Risque suicidaire",
          "fields": [
            {
              "id": "ideation_suicidaire",
              "label": "Idéation suicidaire",
              "type": "select",
              "options": ["absente", "passive", "active_sans_plan", "active_avec_plan"],
              "source": ["consultation", "transcription"],
              "alerts": [
                { "condition": "active_avec_plan", "severity": "critical", "message": "Plan suicidaire — HOSPITALISATION" },
                { "condition": "active_sans_plan", "severity": "high", "message": "Idéation suicidaire active — renforcer suivi" }
              ]
            },
            { "id": "atcd_ts", "label": "ATCD de tentative de suicide", "type": "boolean", "source": ["consultation"] },
            {
              "id": "automutilations",
              "label": "Automutilations",
              "type": "select",
              "options": ["absentes", "occasionnelles", "repetees"],
              "source": ["consultation", "transcription"],
              "alerts": [
                { "condition": "repetees", "severity": "critical", "message": "Automutilations répétées — critère d'hospitalisation" }
              ]
            },
            { "id": "moyens_accessibles", "label": "Moyens létaux accessibles", "type": "boolean", "source": ["consultation"], "alerts": [{ "condition": "true", "severity": "critical", "message": "Moyens létaux accessibles — sécuriser l'environnement" }] }
          ]
        },
        {
          "category": "humeur_anxiete",
          "label": "Humeur et anxiété",
          "fields": [
            { "id": "score_depression", "label": "Score dépression (BDI)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true, "alerts": [{ "condition": "> 29", "severity": "high", "message": "Dépression sévère (BDI > 29)" }] },
            { "id": "score_anxiete", "label": "Score anxiété (STAI/HAM-A)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true },
            { "id": "anxiete_preprandiale", "label": "Anxiété pré-prandiale (EVA 0-10)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true, "alerts": [{ "condition": "> 8", "severity": "moderate", "message": "Anxiété pré-prandiale sévère" }] }
          ]
        },
        {
          "category": "comorbidites",
          "label": "Comorbidités psychiatriques",
          "fields": [
            { "id": "depression", "label": "Épisode dépressif caractérisé", "type": "boolean", "source": ["consultation"] },
            { "id": "toc", "label": "TOC", "type": "boolean", "source": ["consultation"] },
            { "id": "trouble_anxieux", "label": "Trouble anxieux", "type": "boolean", "source": ["consultation"] },
            { "id": "tp", "label": "Trouble de la personnalité", "type": "text", "source": ["consultation"] },
            { "id": "addictions", "label": "Addictions", "type": "text", "source": ["consultation"] },
            { "id": "tsa", "label": "TSA", "type": "boolean", "source": ["consultation"] },
            { "id": "tdah", "label": "TDAH", "type": "boolean", "source": ["consultation"] },
            { "id": "trauma", "label": "Psychotraumatisme identifié", "type": "boolean", "source": ["consultation"] }
          ]
        },
        {
          "category": "prescriptions",
          "label": "Prescriptions",
          "fields": [
            { "id": "medicaments", "label": "Traitements en cours", "type": "medication_list", "source": ["consultation"], "fields_per_item": ["molecule", "posologie", "indication", "date_debut"] },
            { "id": "supplementation", "label": "Supplémentation", "type": "medication_list", "source": ["consultation"] }
          ]
        },
        {
          "category": "motivation",
          "label": "Motivation et alliance",
          "fields": [
            { "id": "stade_motivation", "label": "Stade de motivation (Prochaska)", "type": "select", "options": ["precontemplation", "contemplation", "preparation", "action", "maintien"], "source": ["consultation", "transcription"] },
            { "id": "alliance_therapeutique", "label": "Alliance thérapeutique (EVA 0-10)", "type": "number", "source": ["consultation"] },
            { "id": "deni", "label": "Degré de déni (EVA 0-10)", "type": "number", "source": ["consultation"], "alerts": [{ "condition": "> 7", "severity": "moderate", "message": "Déni important — travail motivationnel prioritaire" }] }
          ]
        },
        {
          "category": "retentissement",
          "label": "Retentissement fonctionnel",
          "fields": [
            { "id": "fonctionnement_social", "label": "Fonctionnement social (EVA 0-10)", "type": "number", "source": ["consultation", "transcription"], "track_history": true },
            { "id": "fonctionnement_scolaire_pro", "label": "Fonctionnement scolaire/professionnel (EVA 0-10)", "type": "number", "source": ["consultation", "transcription"], "track_history": true },
            { "id": "qualite_sommeil", "label": "Qualité sommeil (EVA 0-10)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true }
          ]
        }
      ]
    },
    {
      "id": "psychologue",
      "label": "Psychologue / Psychothérapeute",
      "role": "psychotherapie",
      "frequence_consultation": "hebdomadaire",
      "datasets": [
        {
          "category": "therapie",
          "label": "Suivi psychothérapeutique",
          "fields": [
            { "id": "type_therapie", "label": "Type de thérapie", "type": "select", "options": ["TCC", "FBT_Maudsley", "TIP", "TCD", "psychodynamique", "EMDR", "CRT", "autre"], "source": ["consultation"] },
            { "id": "phase_fbt", "label": "Phase FBT (si applicable)", "type": "select", "options": ["phase_1", "phase_2", "phase_3"], "source": ["consultation"] },
            { "id": "objectifs_therapeutiques", "label": "Objectifs thérapeutiques actuels", "type": "text", "source": ["consultation"] },
            { "id": "progression", "label": "Progression globale (EVA 0-10)", "type": "number", "source": ["consultation"], "track_history": true, "alerts": [{ "condition": "stagnation > 8 semaines", "severity": "moderate", "message": "Stagnation thérapeutique > 2 mois — réévaluer approche" }] }
          ]
        },
        {
          "category": "cognitions",
          "label": "Cognitions et émotions",
          "fields": [
            { "id": "restriction_cognitive", "label": "Restriction cognitive (EVA 0-10)", "type": "number", "source": ["consultation", "transcription"], "track_history": true },
            { "id": "preoccupation_poids", "label": "Préoccupation poids/corps (EVA 0-10)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true },
            { "id": "alexithymie", "label": "Alexithymie suspectée", "type": "boolean", "source": ["consultation"] },
            { "id": "flexibilite_cognitive", "label": "Flexibilité cognitive (si CRT)", "type": "number", "source": ["consultation"], "track_history": true },
            { "id": "image_corporelle_eva", "label": "Satisfaction image corporelle (EVA 0-10)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true }
          ]
        },
        {
          "category": "questionnaires",
          "label": "Questionnaires standardisés",
          "fields": [
            { "id": "edeq_score", "label": "EDE-Q (score global)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true },
            { "id": "edi_score", "label": "EDI (score)", "type": "number", "source": ["consultation"], "track_history": true },
            { "id": "eat26_score", "label": "EAT-26 (score)", "type": "number", "source": ["consultation", "patient_app"], "track_history": true, "alerts": [{ "condition": "> 20", "severity": "moderate", "message": "EAT-26 positif (> 20)" }] },
