  "alert_rules": {
    "description": "Règles d'alerte automatisées combinant les données de plusieurs professionnels",
    "rules": [
      {
        "id": "hospitalisation_somatique",
        "label": "Critères d'hospitalisation somatique (HAS 2010)",
        "logic": "OR",
        "conditions": [
          "imc < seuil_age",
          "fc < 40",
          "pa_systolique < seuil_age",
          "temperature < seuil_age",
          "kaliemie < 3",
          "phosphoremie < 0.5",
          "natremie < 125 OR > 150",
          "glycemie < 0.6 symptomatique OR < 0.3",
          "alat > seuil_age_x_N",
          "leucocytes < 1000",
          "plaquettes < 60000",
          "clairance_creat < 40",
          "ecg_anomalie = true",
          "perte_poids_rapide"
        ],
        "severity": "critical",
        "action": "Hospitalisation recommandée — vérifier critères HAS"
      },
      {
        "id": "hospitalisation_psychiatrique",
        "label": "Critères d'hospitalisation psychiatrique",
        "logic": "OR",
        "conditions": [
          "ideation_suicidaire = active_avec_plan",
          "automutilations = repetees",
          "comorbidite_psy_severe = true"
        ],
        "severity": "critical",
        "action": "Hospitalisation psychiatrique recommandée"
      },
      {
        "id": "stagnation_pec",
        "label": "Stagnation de la PEC ambulatoire",
        "logic": "AND",
        "conditions": [
          "poids stagnant > 4 semaines",
          "progression_therapeutique stagnante > 8 semaines"
        ],
        "severity": "high",
        "action": "Réévaluer la PEC — discuter intensification (HDJ, HTP)"
      },
      {
        "id": "risque_sri",
        "label": "Risque de syndrome de renutrition",
        "logic": "AND",
        "conditions": [
          "renutrition_en_cours = true",
          "phosphoremie en baisse > 20% en 48h"
        ],
        "severity": "critical",
        "action": "ALERTE SRI — surveillance renforcée phosphore quotidien"
      },
      {
        "id": "rdv_manque",
        "label": "RDV manqué",
        "logic": "OR",
        "conditions": [
          "rdv_manque_count >= 2 consecutifs",
          "dernier_rdv > frequence_prevue × 2"
        ],
        "severity": "high",
        "action": "Risque de rupture de soins — recontacter le patient"
      },
      {
        "id": "aggravation_comportementale",
        "label": "Aggravation comportementale",
        "logic": "OR",
        "conditions": [
          "nb_crises_semaine augmentation > 50%",
          "nb_purges_semaine apparition ou augmentation",
          "ap_compulsive = true nouveau",
          "nb_aliments_acceptes en diminution"
        ],
        "severity": "high",
        "action": "Aggravation du TCA — coordonner psy + diét + MG"
      }
    ]
  },

